{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Clone",
  "version": "0.5.0",
  "identifier": "com.kiyooo.clone",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voice Clone",
        "width": 1500,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "kiyooo",
    "targets": [
      "dmg"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src-python/sidecar.py": "src-python/sidecar.py",
      "../src-python/omnivoice_runtime.py": "src-python/omnivoice_runtime.py",
      "../src-python/requirements.txt": "src-python/requirements.txt"
    }
  }
}
